# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5
ANTHROPIC_MODEL_COMPLEX=claude-sonnet-4-6

# ── Z-API (https://z-api.io) ────────────────────────────────────────────────
ZAPI_INSTANCE_ID=xxx
ZAPI_INSTANCE_TOKEN=xxx
ZAPI_CLIENT_TOKEN=xxx

# ── Shopify (loja Cestas Company) ───────────────────────────────────────────
SHOPIFY_DOMAIN=cestas-company.myshopify.com
SHOPIFY_TOKEN=shpat_xxx

# ── Postgres compartilhado com cestas-company ───────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/db

# ── Apps irmãos (para chamadas server-to-server, fase posterior) ────────────
CESTAS_ROUTES_URL=https://cestas-routes-production.up.railway.app
CESTAS_COMPANY_URL=https://cestas-company-production.up.railway.app

# ── Operação ────────────────────────────────────────────────────────────────
PORT=5000
LOG_LEVEL=INFO
MAX_TURNS_PER_SESSION=20
SESSION_TTL_HOURS=24
